}
void lcd16x2_i2c_shiftRight(uint8_t offset) { for(uint8_t i=0; i<offset;i++) lcd16x2_i2c_sendCommand(0x1c); }
void lcd16x2_i2c_shiftLeft(uint8_t offset) { for(uint8_t i=0; i<offset;i++) lcd16x2_i2c_sendCommand(0x18); }
